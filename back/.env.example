NODE_ENV=development
PORT=4000

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=medflow

# JWT
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080

# Frontend (OAuth redirects, links in emails)
FRONTEND_URL=http://localhost:8080

# Public booking (cancel tokens for patient portal)
PUBLIC_BOOKING_SECRET=change-me-booking-secret

# Email (SMTP) — optional in dev (logs to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=MedFlow

# Web Push (VAPID) — run: npm run keys:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@medflow.local

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/integrations/google/callback
