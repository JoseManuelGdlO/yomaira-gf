# =============================================================================
# MedFlow — Variables de entorno para producción (EasyPanel)
# =============================================================================
# Copia este archivo como `.env` en la raíz del repo.
# Docker Compose lee `.env` para back y front (MySQL externo en el servidor).

# -----------------------------------------------------------------------------
# Backend (servicio: back) — dominio: api.tudominio.com
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=4000

# Host del servicio MySQL en EasyPanel (nombre del servicio, ej. mysql)
DB_HOST=mysql
DB_PORT=3306
DB_USER=medflow
DB_PASSWORD=cambiar-password-seguro
DB_NAME=medflow

JWT_SECRET=cambiar-por-string-aleatorio-min-16-chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# Orígenes permitidos (separados por coma, sin espacios extra ni barras finales).
# Incluye localhost para desarrollo local + dominio de producción.
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:8080,https://app.tudominio.com
FRONTEND_URL=https://app.tudominio.com
PUBLIC_BOOKING_SECRET=cambiar-por-string-aleatorio

# Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_FROM_NAME=MedFlow

# Web Push (opcional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@tudominio.com

# Google Calendar OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.tudominio.com/api/v1/integrations/google/callback

# -----------------------------------------------------------------------------
# Frontend (servicio: front) — dominio: app.tudominio.com
# IMPORTANTE: VITE_* se usan en BUILD-TIME; cambiarlas requiere redeploy.
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.tudominio.com/api/v1
VITE_SITE_URL=https://app.tudominio.com
VITE_VAPID_PUBLIC_KEY=
